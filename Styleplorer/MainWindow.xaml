      HorizontalAlignment="Stretch" 
      VerticalAlignment="Center"
      Background="{DynamicResource BorderColorBrush}"
      Visibility="{Binding ElementName=ConsoleBorder2, Path=Visibility}" Panel.ZIndex="1000" DragCompleted="ConsoleSplitter2_DragCompleted"/>
                <Border x:Name="ConsoleBorder2" Grid.Column="1" Grid.Row="3" 
VerticalAlignment="Stretch" HorizontalAlignment="Stretch" 
Background="Black" 
Margin="0,0,0,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Visibility="Collapsed">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="ConsoleTranslate2" Y="200"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBox x:Name="ConsoleOutput2" 
             IsReadOnly="True" Background="Transparent" 
             Foreground="Green" FontFamily="Consolas"
             TextWrapping="Wrap"
             VerticalScrollBarVisibility="Auto" BorderBrush="Transparent" PreviewMouseWheel="ConsoleOutput_PreviewMouseWheel"/>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="CurrentPathBlock2" Grid.Column="0" 
               Text="{Binding ElementName=ActiveListBox2, Path=CurrentPath}" 
               Foreground="White" VerticalAlignment="Center"/>
                            <TextBox x:Name="ConsoleInput2" Grid.Column="1" 
             Background="Transparent" Foreground="White" 
             FontFamily="Consolas" KeyDown="ConsoleInput2_KeyDown" CaretBrush="White"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

        </Grid>
        <!--<Border CornerRadius="10" Background="Transparent" IsHitTestVisible="False" BorderThickness="1" BorderBrush="{DynamicResource WindowBorderColorBrush}">

        </Border>-->
    </Grid>
</Window>