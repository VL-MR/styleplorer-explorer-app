                <local:CustomTabControl x:Name="TabControl2" Grid.Column="1" Grid.Row="1" Background="Transparent" Visibility="Collapsed" BorderThickness="0,1,0,0" Drop="TabControl_Drop" AllowDrop="True" BorderBrush="{DynamicResource BorderColorBrush}"/>
