                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" Margin="0,10,0,10"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="150" Height="150">
                                        <Image Source="{Binding Preview}" Stretch="UniformToFill"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Bottom" HorizontalAlignment="Center" 
                           Foreground="{DynamicResource TextColorBrush}" FontWeight="Bold" Margin="0,0,0,10"/>
