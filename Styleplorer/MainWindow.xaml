                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                                <Button.Content>
                                                    <Path
    Stroke="{DynamicResource TextColorBrush}"
    StrokeThickness="2"
    Fill="Transparent">
                                                        <Path.Data>
                                                            <PathGeometry>
