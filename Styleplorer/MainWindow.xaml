        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <DataTemplate x:Key="FolderTemplate">
            <Border Background="Transparent" Width="100">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.RowSpan="2" ToolTipService.Placement="Mouse">
                        <StackPanel.ToolTip>
                            <ToolTip>
                                <StackPanel>
                                    <TextBlock Text="Folder Information:" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Path}" />
                                </StackPanel>
                            </ToolTip>
                        </StackPanel.ToolTip>
                        <Grid>
                            <Image Source="{Binding StandartFolderIcon1}" Width="100" Height="100" RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image.RenderTransform>
                                    <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                                </Image.RenderTransform>
                            </Image>
                            <Image Source="{Binding Icon}" Width="100" Height="100" RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image.RenderTransform>
                                    <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                                </Image.RenderTransform>
                            </Image>
                            <!--<Image Source="{Binding GroupImage}" Width="24" Height="24" 
                           HorizontalAlignment="Left" VerticalAlignment="Bottom" 
                           Margin="10,0,0,10"/>-->
                        </Grid>
                        <Border Width="50" Height="70" Background="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="30,-110,0,0"
                                Visibility="{Binding FileIcon1, Converter={StaticResource NullToVisibilityConverter}}">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <SkewTransform AngleY="10"/>
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Image Source="{Binding FileIcon1}" Stretch="Fill" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
                        </Border>
                        <Border Width="50" Height="70" Background="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-110,0,0"
                                Visibility="{Binding FileIcon2, Converter={StaticResource NullToVisibilityConverter}}">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <SkewTransform AngleY="15"/>
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Image Source="{Binding FileIcon2}" Stretch="Fill" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
                        </Border>
                        <TextBox IsReadOnly="True" IsHitTestVisible="False" Focusable="False" 
                         Background="Transparent" Foreground="{DynamicResource TextColorBrush}" 
                         BorderBrush="Transparent" BorderThickness="0" Text="{Binding Name}" 
                         Margin="5,0" TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>

                    <!--<Image Grid.Row="0" Grid.RowSpan="2" Source="{Binding StandartFolderIcon2}" 
                   Width="100" Height="100" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                        </Image.RenderTransform>
                    </Image>-->
                    <Grid Grid.Row="0" Grid.RowSpan="2">
                        <Image Source="{Binding StandartFolderIcon2}" 
               Width="100" Height="100" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.5">
                            <Image.RenderTransform>
                                <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                            </Image.RenderTransform>
                        </Image>
                    </Grid>

                    <Grid Grid.Row="0" Grid.RowSpan="2">
                        <Image Source="{Binding GroupImage}" Width="24" Height="24" 
               HorizontalAlignment="Left" VerticalAlignment="Bottom" 
               Margin="10,0,0,20"/>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>


        <!-- Шаблон для дисков -->
        <DataTemplate x:Key="DriveTemplate">
            <Border Background="Transparent" Width="270" Margin="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Image Source="{Binding Icon}" Width="80" Height="60" Margin="0,0,10,0" 
                   Grid.Column="0" Grid.RowSpan="3" VerticalAlignment="Center" Stretch="Uniform"/>

                    <TextBlock Text="{Binding Name}" 
                       Grid.Column="1" Grid.Row="0"
                       Foreground="{DynamicResource TextColorBrush}"
                       TextWrapping="Wrap" 
                       Margin="0,0,0,5"/>

                    <ProgressBar Value="{Binding UsedSpacePercentage, Mode=OneWay}" 
                         Grid.Column="1" Grid.Row="1"
                         Minimum="0"
                         Maximum="100" 
                         Height="10" 
                         Margin="0,0,0,5">
                        <ProgressBar.Foreground>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="#FF3A7BD5" Offset="0"/>
                                <GradientStop Color="#FF00D2FF" Offset="1"/>
                            </LinearGradientBrush>
                        </ProgressBar.Foreground>
                    </ProgressBar>

                    <TextBlock Text="{Binding FreeSpaceFormatted}" 
                       Grid.Column="1" Grid.Row="2"
                       Foreground="{DynamicResource TextColorBrush}" 
                       FontSize="11"/>
                </Grid>
            </Border>
        </DataTemplate>





        <!-- Контекстное меню для файлов -->
        <ContextMenu x:Key="FileContextMenu" Closed="ContextMenu_Closed">
            <MenuItem Header="Открыть" Click="Open" />
            <MenuItem Header="Удалить" Click="Delete" />
            <MenuItem Header="Переименовать" Click="Rename" />
            <MenuItem Header="Свойства" Click="Properties " />
        </ContextMenu>

        <!-- Контекстное меню для папок -->
        <ContextMenu x:Key="FolderContextMenu" Closed="ContextMenu_Closed">
            <MenuItem Header="Открыть" Click="Open" />
            <MenuItem Header="Удалить" Click="Delete" />
            <MenuItem Header="Переименовать" Click="Rename" />
            <MenuItem Header="" x:Name="FavoriteMenuItem" Click="ToggleFavorite" />
            <MenuItem Header="Группа" x:Name="GroupMenuItem" />
            <MenuItem Header="Архивировать" Click="Archive_Click"/>
            <MenuItem Header="Свойства" Click="Properties " />
        </ContextMenu>

        <!-- Контекстное меню для дисков -->
        <ContextMenu x:Key="DriveContextMenu" Closed="ContextMenu_Closed">
            <MenuItem Header="Открыть" Click="Open" />
            <MenuItem Header="Удалить" Click="Delete" />
            <MenuItem Header="Переименовать" Click="Rename" />
            <MenuItem Header="Свойства" Click="Properties " />
        </ContextMenu>

        <!-- Контекстное меню для пустого места -->
        <ContextMenu x:Key="EmptyContextMenu" Closed="ContextMenu_Closed">
            <MenuItem Header="Обновить" Click="Refresh" />
            <MenuItem Header="Вид">
                <!--<MenuItem x:Name="HugeIcons" Header="Огромные значки" Click="ViewMenuItem_Click"/>-->
                <!--<MenuItem x:Name="BigIcons" Header="Крупные значки" Click="ViewMenuItem_Click"/>-->
                <MenuItem x:Name="NormalIcons" Header="Обычные значки" Click="ViewMenuItem_Click"/>
                <!--<MenuItem x:Name="SmallIcons" Header="Мелкие значки" Click="ViewMenuItem_Click"/>-->
                <!--<MenuItem x:Name="ViewList" Header="Список" Click="ViewMenuItem_Click"/>-->
                <MenuItem x:Name="ViewTable" Header="Таблица" Click="ViewMenuItem_Click"/>
                <!--<MenuItem Header="Плитка" Click="ViewMenuItem_Click"/>
                <MenuItem Header="Содержимое" Click="ViewMenuItem_Click"/>-->
            </MenuItem>
        </ContextMenu>

        <DataTemplate x:Key="ListView">
            <StackPanel Orientation="Horizontal">
                <Image Source="{Binding Icon}" Width="20" Height="20" />
                <TextBlock Text="{Binding Name}" Margin="5,0" />
            </StackPanel>
        </DataTemplate>

        <!-- Шаблон вида списка -->
        <DataTemplate x:Key="ListViewTemplate">
            <Border Background="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.ToolTip>
                        <ToolTip>
                            <StackPanel>
                                <TextBlock Text="File Information:" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Path}" />
                            </StackPanel>
                        </ToolTip>
                    </Grid.ToolTip>
                    <Image Source="{Binding Icon}" Width="24" Height="24" Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" Foreground="{DynamicResource TextColorBrush}"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Шаблон вида таблицы -->
        <DataTemplate x:Key="TableViewTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.ToolTip>
                    <ToolTip>
                        <StackPanel>
                            <TextBlock Text="File Information:" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Path}" />
                        </StackPanel>
                    </ToolTip>
                </Grid.ToolTip>
                <Image Source="{Binding Icon}" Width="24" Height="24" Grid.Column="0" Margin="2"/>
                <TextBlock Text="{Binding Name}" Grid.Column="1" VerticalAlignment="Center" Margin="2"/>
                <TextBlock Text="{Binding Size}" Grid.Column="2" VerticalAlignment="Center" Margin="2"/>
                <TextBlock Text="{Binding Type}" Grid.Column="3" VerticalAlignment="Center" Margin="2"/>
                <TextBlock Text="{Binding DateChanged, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Grid.Column="4" VerticalAlignment="Center" Margin="2"/>
            </Grid>
        </DataTemplate>

        <Style x:Key="GridViewItemStyle" TargetType="{x:Type ListViewItem}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListViewItem}">
                        <Border Background="{TemplateBinding Background}">
                            <GridViewRowPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="Gray"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>





        <local:FileFolderTemplateSelector x:Key="FileFolderTemplateSelector"
                                      FileTemplate="{StaticResource FileTemplate}"
                                      FolderTemplate="{StaticResource FolderTemplate}"
                                      DriveTemplate="{StaticResource DriveTemplate}" />

        <Style x:Key="BaseTabItemStyle" TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" BorderThickness="1,1,1,0" BorderBrush="{DynamicResource BorderColorBrush}" CornerRadius="4,4,0,0">
                            <Grid>
                                <TextBlock x:Name="HeaderText"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="12,2,12,2"
                                   Text="{TemplateBinding Header}"
                                   Foreground="{DynamicResource TextColorBrush}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="Gray" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="Transparent" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="ClosableTabItemStyle" TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" BorderThickness="1,1,1,0" BorderBrush="{DynamicResource BorderColorBrush}" CornerRadius="4,4,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="HeaderText"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   Margin="12,2,12,2"
                                   Text="{TemplateBinding Header}"
                                   Foreground="{DynamicResource TextColorBrush}"/>
                                <Button x:Name="CloseButton"
                                Grid.Column="1"
                                Content="X"
                                Width="16" Height="16"
                                Margin="0,0,5,0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right"
                                BorderThickness="0"
                                Background="Transparent"
                                Foreground="{DynamicResource TextColorBrush}"
                                Click="CloseTab_Click"
                                Tag="{Binding RelativeSource={RelativeSource AncestorType=TabItem}}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="Gray" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="Transparent" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <local:TextTrimConverter x:Key="TextTrimConverter"/>
        <!--<sys:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>-->
        <!--<local:InverseBooleanConverter x:Key="InverseBooleanConverter"/>-->
        <Style TargetType="Button" x:Key="PathElementStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="2,0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColorBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SideMenuHighlightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Key="ShowConsole" Completed="ShowConsole_Completed">
            <DoubleAnimation Storyboard.TargetName="ConsoleTranslate" 
                         Storyboard.TargetProperty="Y"
                         To="0" Duration="0:0:0.3"/>
        </Storyboard>
        <Storyboard x:Key="HideConsole">
            <DoubleAnimation Storyboard.TargetName="ConsoleTranslate" 
                         Storyboard.TargetProperty="Y"
                         To="200" Duration="0:0:0.3"/>
        </Storyboard>

        <Storyboard x:Key="ShowConsole2">
            <DoubleAnimation Storyboard.TargetName="ConsoleTranslate2" 
                     Storyboard.TargetProperty="Y" 
                     From="200" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="HideConsole2">
            <DoubleAnimation Storyboard.TargetName="ConsoleTranslate2" 
                     Storyboard.TargetProperty="Y" 
                     From="0" To="200" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Style x:Key="TransparentButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColorBrush}" />
            <Setter Property="Height" Value="80"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColorBrush}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SideMenuHighlightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExpanderButtonStyle" TargetType="Expander">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColorBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColorBrush}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border x:Name="HeaderBorder" Background="{TemplateBinding Background}" 
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Height="80">
                                <Grid>
                                    <ContentPresenter ContentSource="Header" 
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                                    <Button x:Name="ExpanderButton" 
                                  Opacity="0"
                                  Click="ExpanderButton_Click"/>
                                </Grid>
                            </Border>
                            <Border x:Name="ContentBorder" Grid.Row="1" MaxHeight="0">
                                <ContentPresenter x:Name="ExpanderContent" 
                                  Content="{TemplateBinding Content}"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ContentBorder" 
                                             Storyboard.TargetProperty="MaxHeight"
                                             From="0" To="200" Duration="0:0:0.3"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ContentBorder" 
                                             Storyboard.TargetProperty="MaxHeight"
                                             From="200" To="0" Duration="0:0:0.3"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource SideMenuHighlightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InnerExpanderButtonStyle" TargetType="Expander">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColorBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColorBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border x:Name="HeaderBorder" Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Height="30">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Image x:Name="HeaderImage" Source="{Binding Image}" Grid.Column="0" Width="20" Height="20" Margin="5,0,5,0"/>
                                    <ContentPresenter Grid.Column="1" ContentSource="Header" 
                                      HorizontalAlignment="Left" 
                                      VerticalAlignment="Center"/>
                                    <Button x:Name="EditButton" Grid.Column="2" Content="🖉" 
        Width="30" Height="30" BorderBrush="Transparent" FontSize="20"
        VerticalAlignment="Center" HorizontalAlignment="Left"
        Style="{StaticResource TransparentButtonStyle}"
        Click="EditGroup_Click"
        Panel.ZIndex="1"/>
                                    <!--✎✐✏🖉-->
                                    <Button x:Name="DeleteButton" Grid.Column="3" Content="✕" 
                                    Width="20" Height="30" Margin="0,0,5,0" BorderBrush="Transparent"
                                    VerticalAlignment="Center" HorizontalAlignment="Left"
                                    Style="{StaticResource TransparentButtonStyle}"
                                    Click="DeleteGroup_Click"
                                    Panel.ZIndex="1"/>
                                    <Button x:Name="ExpanderButton" 
                            Grid.ColumnSpan="3"
                            Opacity="0"
                            Click="ExpanderButton_Click"/>
                                </Grid>
                            </Border>
                            <Border x:Name="ContentBorder" Grid.Row="1" MaxHeight="0">
                                <ContentPresenter x:Name="ExpanderContent" 
                                          Content="{TemplateBinding Content}"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ContentBorder" 
                                                     Storyboard.TargetProperty="MaxHeight"
                                                     From="0" To="100" Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction>
                                                    <ExponentialEase EasingMode="EaseOut" Exponent="5"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ContentBorder" 
                                                     Storyboard.TargetProperty="MaxHeight"
                                                     To="0" Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction>
                                                    <ExponentialEase EasingMode="EaseIn" Exponent="5"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource SideMenuHighlightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

