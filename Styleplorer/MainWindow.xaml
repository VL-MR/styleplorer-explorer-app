                    <Grid.ToolTip>
                        <ToolTip>
                            <StackPanel>
                                <TextBlock Text="File Information:" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Path}" />
                            </StackPanel>
                        </ToolTip>
                    </Grid.ToolTip>
                    <Image Source="{Binding Icon}" Grid.Column="0" Width="24" Height="24" Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1" Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" HorizontalAlignment="Stretch" Foreground="{DynamicResource TextColorBrush}"/>
