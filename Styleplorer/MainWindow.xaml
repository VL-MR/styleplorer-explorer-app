                            <Button x:Name="OpenConsoleBtn2" Content="^" Grid.Column="2" Click="ShowConsole2_Click" HorizontalAlignment="Right" Width="30" Height="20" VerticalAlignment="Center" Background="Transparent" Foreground="{DynamicResource TextColorBrush}"/>
