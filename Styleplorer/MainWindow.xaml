                <Border x:Name="Border2" Grid.Column="1" Grid.Row="4" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Background="{DynamicResource BottomPanelBrush}" Margin="0,0,1.5,1.5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
