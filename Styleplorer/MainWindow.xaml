            <Border x:Name="SideMenu" Background="{DynamicResource SideMenuBrush}" HorizontalAlignment="Left" Width="250" VerticalAlignment="Stretch" BorderBrush="{DynamicResource BorderColorBrush}" BorderThickness="0,0,1,0">
